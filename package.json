{
  "name": "quick-eats",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "build": "npm install --workspaces --include=dev && npm run build --workspace=client",
    "start": "npm run start --workspace=server",
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=client\" "
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
